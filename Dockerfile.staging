FROM registry.cn-hangzhou.aliyuncs.com/devflow/golang:1.25.7 AS builder

WORKDIR /workspace
ENV GOPROXY=https://goproxy.cn,direct

COPY devflow-service-common /workspace/devflow-service-common
COPY devflow-app-service /workspace/devflow-app-service

WORKDIR /workspace/devflow-app-service
RUN go mod download
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/devflow-app-service ./cmd

FROM scratch
WORKDIR /app
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=builder /out/devflow-app-service ./devflow-app-service
COPY --from=builder /workspace/devflow-app-service/docs ./docs
EXPOSE 8081
USER 65532:65532
ENTRYPOINT ["/app/devflow-app-service"]
